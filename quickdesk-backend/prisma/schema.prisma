
generator client {
  provider = "prisma-client-js"
  
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//------User Schema----------------

model User {
  id            String             @id @default(cuid())
  name          String
  email         String             @unique
  password      String
  role          Role               @default(EMPLOYEE)
  tickets       Ticket[]
  overrideLogs  OverrideAuditLog[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}


model Ticket {

  id          Int              @id @default(autoincrement())
  title       String
  description String
  attachment  String?
  status      TicketStatus     @default(OPEN)
  category    TicketCategory   @default(OTHER)
  priority    TicketPriority   @default(MEDIUM)
  aiSuggested Boolean          @default(true)
  aiDraftReply String?
  aiCitations  Json?
  finalReply  String?
  resolvedAt  DateTime?
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  overrideLogs OverrideAuditLog[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

}

model OverrideAuditLog {
  id        Int      @id @default(autoincrement())
  ticketId  Int
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  agentId   String
  agent     User     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  field     String
  fromValue String
  toValue   String
  createdAt DateTime @default(now())
}

enum Role {
  EMPLOYEE
  AGENT
}

//------------Ticket----------------

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum TicketCategory {
  IT
  HR
  FINANCE
  ADMIN
  OTHER
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}
